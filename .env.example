# LLM Provider: "anthropic" or "bedrock"
LLM_PROVIDER=anthropic

# Anthropic API Configuration (if using LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=your_api_key_here

# AWS Bedrock Configuration (if using LLM_PROVIDER=bedrock)
# Use AWS Bedrock bearer token (ABSK... format from AWS console)
AWS_BEARER_TOKEN_BEDROCK=your_absk_bearer_token_here
AWS_REGION=us-east-1

# FastAPI Configuration
API_HOST=0.0.0.0
API_PORT=8000

# LangSmith (optional for tracing)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=bd-intelligence

# Tavily Search API (for web research)
TAVILY_API_KEY=your_tavily_api_key_here
